    Price     float64          // 电价值
}
```

### 4. 日期范围配置 (SDateRange)

```go
type SDateRange struct {
    StartDate  string // 开始日期 "YYYY-MM-DD" 格式
    EndDate    string // 结束日期 "YYYY-MM-DD" 格式
