# EMS Plan 开发环境 Docker 镜像
# 基于最佳实践的多阶段构建

# 第一阶段：C++ 编译阶段
FROM gcc:latest AS cpp-builder

# 安装构建工具
RUN apt-get update && apt-get install -y \
    make \
    cmake \
    git \
    && rm -rf /var/lib/apt/lists/*

# 设置工作目录
WORKDIR /app

# 复制 C++ 源代码
COPY @cpp/ ./@cpp/

# 编译 C++ 库
WORKDIR /app/@cpp
RUN make clean && make

# 第二阶段：Go 构建阶段
FROM golang:1.25-alpine AS go-builder

# 安装构建依赖
RUN apk add --no-cache \
    musl-dev \
    git \
    bash \
    ca-certificates \
    libc6-compat

# 设置 Go 环境变量
ENV GO111MODULE=on \
    GOPROXY=https://goproxy.cn,direct \
    GOSUMDB=sum.golang.google.cn \
    CGO_ENABLED=1 \
    GOOS=linux \
    GOARCH=amd64

# 设置工作目录
WORKDIR /app

# 复制 go.work 文件
COPY go.work go.work.sum ./

# 复制完整的源代码
COPY application/ ./application/
COPY common/ ./common/
COPY services/ ./services/
COPY plugins/ ./plugins/
COPY tools/ ./tools/
COPY @cpp/ ./@cpp/

# 从 C++ 构建阶段复制编译好的库文件
COPY --from=cpp-builder /app/@cpp/build/libhexlib.so ./application/lib/

# 修复依赖并编译 EMS 程序
WORKDIR /app/application
RUN go mod tidy && \
    CGO_ENABLED=1 go build \
    -tags=dev \
    -ldflags="-w -s" \
    -o ems main.go

# 第三阶段：运行时镜像
FROM alpine:latest AS runtime

# 安装运行时依赖
RUN apk add --no-cache \
    ca-certificates \
    bash \
    libgcc \
    libstdc++

# 设置工作目录
WORKDIR /app

# 从 Go 构建阶段复制编译好的程序
COPY --from=go-builder /app/application/ems ./ems
COPY --from=go-builder /app/application/manifest ./manifest
COPY --from=go-builder /app/application/lib ./lib

# 创建必要的目录
RUN mkdir -p ./out/logs ./out/data ./out/static ./out/ptdb

# 设置环境变量
ENV LD_LIBRARY_PATH=/app/lib

# 暴露端口
EXPOSE 80

# 启动命令
CMD ["./ems", "--web=true", "--profile=prod"]
